<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/nexus_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hidden binding views that ConnectFragment.kt requires -->
        <ImageView
            android:id="@+id/ivStatus"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="invisible"
            android:contentDescription="status"
            tools:ignore="SmallSp" />

        <ImageView
            android:id="@+id/ivShadow"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="invisible"
            android:contentDescription="shadow" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="@android:style/Widget.DeviceDefault.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressTint="@color/nexus_accent"
            android:progressBackgroundTint="@color/nexus_card_bg"
            android:visibility="invisible"
            tools:progress="50"
            tools:visibility="visible" />

        <!-- ═══════════ HEADER ═══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:gravity="center_vertical"
            android:background="@color/nexus_background">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_shield"
                android:adjustViewBounds="true"
                android:contentDescription="logo"
                app:tint="@color/nexus_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.06"
                android:text="NEXUS"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text=" _vpn"
                android:textColor="@color/nexus_accent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="14dp"
                android:src="@drawable/ic_settings_gear"
                android:adjustViewBounds="true"
                android:contentDescription="settings"
                app:tint="#556080" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_kindness_outline"
                android:adjustViewBounds="true"
                android:contentDescription="theme"
                app:tint="#556080" />

        </LinearLayout>

        <!-- Subtitle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:letterSpacing="0.12"
            android:paddingBottom="8dp"
            android:text="SECURE ANONYMOUS TUNNEL PROTOCOL"
            android:textColor="@color/nexus_text_secondary"
            android:textSize="9sp" />

        <!-- Network scope bar -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_network_scope"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="5dp"
            android:paddingEnd="12dp"
            android:paddingBottom="5dp">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/btn_power_circle"
                android:backgroundTint="@color/nexus_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.04"
                android:text="NETWORK SCOPE: 88+ COUNTRIES AVAILABLE (DYNAMIC TOR RELAY)"
                android:textColor="@color/nexus_accent"
                android:textSize="8sp" />

        </LinearLayout>

        <!-- ═══════════ MAIN DASHBOARD CARD ═══════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#0D1526"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- ── STATUS ROW ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="10dp">

                    <!-- STATUS label + badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.1"
                            android:text="STATUS"
                            android:textColor="@color/nexus_text_secondary"
                            android:textSize="9sp" />

                        <!-- tvTitle used as status badge -->
                        <TextView
                            android:id="@+id/tvTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bg_tag_red"
                            android:fontFamily="monospace"
                            android:paddingStart="6dp"
                            android:paddingTop="2dp"
                            android:paddingEnd="6dp"
                            android:paddingBottom="2dp"
                            android:text="Offline"
                            android:textColor="#FF5555"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            tools:text="Offline" />

                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <!-- EXIT NODE ADDRESS -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:letterSpacing="0.06"
                            android:text="↑ EXIT NODE ADDRESS"
                            android:textColor="@color/nexus_accent"
                            android:textSize="8sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="---,---,---,---"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:letterSpacing="0.04"
                        android:text="⟳ ROTATE IP"
                        android:textColor="@color/nexus_accent"
                        android:textSize="9sp" />

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1A2A3A"
                    android:layout_marginBottom="12dp" />

                <!-- ── POWER BUTTON + INFO ROW ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="12dp">

                    <!-- Left: Power button + System Idle + Session -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:layout_marginEnd="16dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnStart"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="78dp"
                            android:layout_height="78dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:textColor="#00000000"
                            android:backgroundTint="@color/panel_widget_background"
                            app:cornerRadius="39dp"
                            app:strokeColor="@color/nexus_accent"
                            app:strokeWidth="2dp"
                            app:icon="@drawable/ic_power"
                            app:iconTint="@color/nexus_accent"
                            app:iconSize="32dp"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            android:paddingStart="0dp"
                            android:paddingEnd="0dp"
                            android:text="" />

                        <!-- tvSubtitle positioned below power button -->
                        <TextView
                            android:id="@+id/tvSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="System Idle"
                            android:textColor="@color/nexus_text_secondary"
                            android:textSize="10sp"
                            tools:text="System Idle" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="monospace"
                            android:gravity="center"
                            android:text="0 SESSION   00:00"
                            android:textColor="#3D5A80"
                            android:textSize="9sp" />

                    </LinearLayout>

                    <!-- Right: Location + Daemon Status stacked -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- Location + Daemon Status row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- LOCATION -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:paddingEnd="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="3dp"
                                    android:letterSpacing="0.06"
                                    android:text="⊕ LOCATION"
                                    android:textColor="@color/nexus_text_secondary"
                                    android:textSize="8sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Unknown Region"
                                    android:textColor="@android:color/white"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <!-- DAEMON STATUS -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginBottom="3dp"
                                    android:letterSpacing="0.06"
                                    android:text="⟳ DAEMON STATUS"
                                    android:textColor="@color/nexus_text_secondary"
                                    android:textSize="8sp" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <View
                                        android:layout_width="6dp"
                                        android:layout_height="6dp"
                                        android:layout_marginEnd="4dp"
                                        android:background="@drawable/btn_power_circle"
                                        android:backgroundTint="@color/nexus_accent" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Connected and bootstrapped"
                                        android:textColor="@android:color/white"
                                        android:textSize="9sp" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1A2A3A"
                    android:layout_marginBottom="10dp" />

                <!-- ── BANDWIDTH ACTIVITY ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.06"
                        android:text="▣ BANDWIDTH ACTIVITY"
                        android:textColor="@color/nexus_text_secondary"
                        android:textSize="8sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="▶ IDLE"
                        android:textColor="@color/nexus_text_secondary"
                        android:textSize="8sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="10dp"
                    android:text="• Ping: --ms  ↓ -- -- MB/s  ↑ -- -- MB/s  Traffic: --Unknown"
                    android:textColor="#3D7A3D"
                    android:textSize="9sp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1A2A3A"
                    android:layout_marginBottom="10dp" />

                <!-- ── PROTOCOL / PORT / ENCRYPTION ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:letterSpacing="0.08"
                            android:text="PROTOCOL"
                            android:textColor="@color/nexus_text_secondary"
                            android:textSize="8sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="SOCKS5"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:letterSpacing="0.08"
                            android:text="PORT"
                            android:textColor="@color/nexus_text_secondary"
                            android:textSize="8sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="9050"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="3dp"
                            android:letterSpacing="0.08"
                            android:text="ENCRYPTION"
                            android:textColor="@color/nexus_text_secondary"
                            android:textSize="8sp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="monospace"
                                android:text="⊙ AES-256"
                                android:textColor="@color/nexus_accent"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Hidden original items — ConnectFragment.kt controls their visibility -->
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/swSmartConnect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/run_smart_connect_"
                    android:textColor="@color/nexus_text_secondary"
                    android:textSize="11sp"
                    android:visibility="gone"
                    app:switchPadding="8dp" />

                <TextView
                    android:id="@+id/tvConfigure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/btn_configure"
                    android:textAllCaps="true"
                    android:textColor="@color/nexus_accent"
                    android:textSize="10sp"
                    android:visibility="gone" />

                <ListView
                    android:id="@+id/lvConnected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:dividerHeight="1dp"
                    android:visibility="gone"
                    tools:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ═══════════ TERMINAL SESSION ═══════════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#060A12"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Terminal header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.12"
                        android:text="TERMINAL SESSION"
                        android:textColor="@color/nexus_accent"
                        android:textSize="9sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <View
                        android:layout_width="6dp"
                        android:layout_height="6dp"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/btn_power_circle"
                        android:backgroundTint="@color/nexus_live_red" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.12"
                        android:text="LIVE"
                        android:textColor="@color/nexus_live_red"
                        android:textSize="9sp" />

                </LinearLayout>

                <!-- Terminal log lines -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.5"
                    android:text="[10:35:04] [System] Initializing Network Operations Center\n[10:35:04] [System] Verifying cryptographic protocols\n[10:35:05] [Daemon] Tor circuit established. Ready for connections."
                    android:textColor="@color/nexus_accent"
                    android:textSize="10sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ═══════════ FOOTER LINKS ═══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.04"
                    android:text="ABOUT US"
                    android:textColor="@color/nexus_text_secondary"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:text="|"
                    android:textColor="#2A3A4A"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.04"
                    android:text="PRIVACY POLICY"
                    android:textColor="@color/nexus_text_secondary"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:text="|"
                    android:textColor="#2A3A4A"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.04"
                    android:text="TERMS OF SERVICE"
                    android:textColor="@color/nexus_text_secondary"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:text="|"
                    android:textColor="#2A3A4A"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.04"
                    android:text="CONTACT SUPPORT"
                    android:textColor="@color/nexus_text_secondary"
                    android:textSize="9sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="© 2025 NEXUS VPN by Riaz Ali Shahani  |  Open-Source Privacy Routing"
                android:textColor="#2A3A4A"
                android:textSize="8sp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
